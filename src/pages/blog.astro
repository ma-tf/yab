---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogPost from "../components/BlogPost.astro";
import { getCollection } from "astro:content";
import { BASE_PATH } from "../config";

const allPosts = (await getCollection("blog")).filter(
	(post) => !post.data.draft,
);
const pageTitle = "Matt's blog";
---

<BaseLayout pageTitle={pageTitle}>
	<div class="mt-8">
		<p>Thoughts and feelings on various topics.</p>
	</div>
	<div class="flex flex-col gap-4 mt-8">
		{
			allPosts
				.sort((a, b) => b.data.slug.localeCompare(a.data.slug))
				.map((post) => (
					<BlogPost url={`${BASE_PATH}posts/${post.data.slug}`} data={post.data} />
				))
		}
	</div>
</BaseLayout>
