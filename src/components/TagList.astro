---
interface Props {
	tags: string[];
}
const { tags } = Astro.props;
import { BASE_PATH } from "../config";
---

<div class="flex gap-2">
	{
		tags.map((tag: string) => (
			<p class="text-lg">
				<a
					class="text-link hover:text-link-hover underline"
					href={`${BASE_PATH}tags/${tag}`}
				>
					{tag}
				</a>
			</p>
		))
	}
</div>
