---
const { tags } = Astro.props;
import { BASE_PATH } from "../config";
---

<div class="flex flex-wrap">
	{
		tags.map((tag: string) => (
			<p class="m-1 border border-dotted border-gray-400 rounded-lg px-4 py-2 text-lg bg-slate-50">
				<a href={`${BASE_PATH}tags/${tag}`}>{tag}</a>
			</p>
		))
	}
</div>
